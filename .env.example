# Vertex AI 인증 모드 — 둘 중 하나만 채우면 됩니다.

# [모드 A] Vertex AI Express Mode — API 키 한 개만 사용
GOOGLE_API_KEY=

# [모드 B] Application Default Credentials — project + location 사용
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# 두 모드 모두 필수
VERTEX_AI_MODEL=gemini-2.5-flash
